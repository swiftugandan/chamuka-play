# ── Choose ONE way to power game generation ──────────────────────────────────

# Option A (recommended, free, NO credit card): Google Gemini via AI Studio.
# Get a key at https://aistudio.google.com/apikey — free tier, no card needed.
# When set, the app uses Gemini directly (ignores the Gateway settings below).
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional Gemini model override (default: gemini-2.5-flash)
GEMINI_MODEL=

# Option B: Vercel AI Gateway. For local dev set your AI Gateway key.
# On Vercel, OIDC handles auth automatically. Note: the Gateway free tier
# generally requires a card on file for verification.
AI_GATEWAY_API_KEY=
# Gateway model slug (used only when no GOOGLE_GENERATIVE_AI_API_KEY is set).
# Higher quality: anthropic/claude-sonnet-4.6 · cheaper: anthropic/claude-haiku-4.5
GAME_MODEL=google/gemini-3.5-flash

# Option C: no key at all — set MOCK_AI=1 to run a real, playable demo game
# offline (great for local dev / showcasing without any provider).
MOCK_AI=
