# Vercel AI Gateway. For local dev set this to your AI Gateway API key.
# On Vercel, OIDC handles auth automatically and this can be omitted.
AI_GATEWAY_API_KEY=

# Game generation model — a verified Vercel AI Gateway slug.
# Default is a cheap, fast, capable model good for single-file games.
# Higher quality options: anthropic/claude-sonnet-4.6, anthropic/claude-opus-4.8
# Other cheap options: anthropic/claude-haiku-4.5, google/gemini-3-flash
GAME_MODEL=google/gemini-3.5-flash
